{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development PORT=3333 tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production PORT=3333 node dist/index.js",
    "check": "tsc",
    "db:push": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs push",
    "create-admin": "tsx scripts/create-admin.ts",
    "init-badges": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/init-badges.ts",
    "seed:math": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/seed-math-problems.ts",
    "seed:language": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/seed-language-problems.ts",
    "seed:cruiseword": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/seed-cruiseword-words.ts",
    "seed:games": "npm run seed:math && npm run seed:language && npm run seed:cruiseword",
    "setup:games": "npm run db:push && npm run init-badges && npm run seed:games",
    "diagnose": "node scripts/diagnose-api.mjs http://localhost:5000",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
