# =============================================
# Keru.ai Suite — Environment Variables
# Copy to .env and fill in your values
# =============================================

# Required — Web Interface
# Local: postgresql://postgres:YOUR_PASSWORD@localhost:5432/studybuddyai
# Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/studybuddyai
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Required — AI Features (Study Buddy, Telegram Bot)
OPENAI_API_KEY=your_openai_api_key_here

# Optional — AI Fallback (used when OpenAI fails; also used when N8N is not configured)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional — N8N workflow AI (StudyBuddy tutor chat). One webhook per persona (each tutor has its own workflow).
# Set N8N_WEBHOOK_<AGENT_KEY> with agentKey in UPPER_SNAKE_CASE (e.g. matematico_guia → N8N_WEBHOOK_MATEMATICO_GUIA).
# When a webhook is set for the current tutor, chat calls it first; otherwise falls back to OpenAI/Perplexity.
# N8N_WEBHOOK_MATEMATICO_GUIA=https://your-n8n.com/webhook/matematico-guia
# N8N_SKIP_CACHE=true
# N8N_DEBUG=true
# N8N_TIMEOUT_MS=90000
# N8N_WEBHOOK_DOCTORA_NOVA=https://your-n8n.com/webhook/doctora-nova
# N8N_WEBHOOK_PROFESOR_PLUMA=https://your-n8n.com/webhook/profesor-pluma
# N8N_WEBHOOK_MAESTRO_CIENCIAS=https://your-n8n.com/webhook/maestro-ciencias
# N8N_WEBHOOK_MAESTRO_CIVISMO=https://your-n8n.com/webhook/maestro-civismo
# N8N_WEBHOOK_GUIA_INFORMATICA=https://your-n8n.com/webhook/guia-informatica
# Fallback for any agent without a dedicated webhook (optional):
# N8N_PERSONA_CHAT_URL=https://your-n8n.com/webhook/persona-chat

# Optional — Telegram Bot (separate deployment)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional — Web Interface (local development)
# On Windows, port 5000 may be reserved; set PORT=3000 and update VITE_API_URL
PORT=5000
VITE_API_URL=http://localhost:5000

# Offline / PWA: set to true when platform is ready for offline (default: off for test/dev)
# VITE_OFFLINE_ENABLED=true

# Optional — GitHub Integration
GITHUB_TOKEN=your_github_token_here

# Environment
NODE_ENV=development

# Optional — Debug/agent ingest (only when debugging; leave unset in production)
# DEBUG_AGENT_INGEST=true
# VITE_DEBUG_AGENT_INGEST=true

# Optional — Study materials / assign flow: logs [StudyMaterials] in server terminal (dev: on by default)
# DEBUG_STUDY_MATERIALS=1
